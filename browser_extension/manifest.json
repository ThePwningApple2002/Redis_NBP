{
    "manifest_version": 3,
    "name": "Recipe scraper",
    "version": "1.0",
    "description": "Scrapes cooking recipes.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "http://127.0.0.1/*",
        "http://localhost/*"
    ],
    "icons": {
        "128": "chef-hat.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "128": "chef-hat.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}